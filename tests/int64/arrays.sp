native void printnum64(int64 a);

int64 blah[10] = {
    123456789123456789,
    234567891234567891,
    345678912345678912,
    456789123456789123,
    567891234567891234,
    678912345678912345,
    789123456789123456,
    891234567891234567,
    912345678912345678,
    123456789123456789
};

public void main() {
    printnum64(sizeof(blah));
    blah[5] = 9999999999999999;
    for (int i = 0; i < 10; i++)
        printnum64(blah[i]);
}
